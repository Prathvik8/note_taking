<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
 
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form px-10 py-10 text-white">
            <form action="/create" method="post">
                <input class="block px-5 py-2 bg-zinc-800 w-full  rounded-md outline-none" type="text" placeholder="title goes here" name="title">
                <textarea class="block px-5 py-2 bg-zinc-800 resize-none mt-2 w-full rounded-md outline-none"  placeholder="Write your task details" name="details"></textarea>
                <input class="mt-2 bg-blue-600  px-5 py-2 rounded-md" type="submit" value="Create Task">
            </form>
        </div>
        <div class="tasks flex gap-3 flex-wrap">
          <% if(files.length>0){ %>
                <% files.forEach(function(val){ %>
                    <div class="task ml-10 w-72 px-3 py-4 bg-zinc-800 rounded-md">
                <h1 class="text-white text-3xl tracking-tighter"><%= val %></h1>
                <div class="flex justify-between mt-3">
                    <a class="text-blue-500 inline-block " href ="/part7/files/<%=val%>">Read More</a>
                    <a class="text-zinc-600" href="/part7/views/edit/<%=val %>" >edit file name</a>
                </div>
            </div>
            
                <% })%>
          <%} else {%>
                 <h1 class="text-zinc-600 py-10 px-10">No task yet.</h1>
          <%}%>
            
            
           

        </div>
    </div>
    
    
</body>
</html>